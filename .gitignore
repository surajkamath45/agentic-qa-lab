# =============================================================================
# Agentic QA Lab — .gitignore
# =============================================================================

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/
.python-version

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity

# =============================================================================
# Playwright
# =============================================================================
# Test results & reports (generated, not source)
playwright-report/
test-results/
.playwright/

# =============================================================================
# Generated Output Artifacts
# =============================================================================
# These are generated at runtime — commit the src, not the output
output/logs/
output/manifest.json
output/healed_scripts/
output/risk_report.md

# Keep the output directory itself tracked (but not its contents)
# Add a .gitkeep inside output/logs/ and output/healed_scripts/ if needed

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# OS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Misc
# =============================================================================
*.log
*.tmp
*.bak
